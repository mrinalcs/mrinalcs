  "content": "<style>.k-column {\n    padding-bottom: 10px;\n} \n.section {\n  margin-top: 20px;\n}\n.hero {\n  background-image: url('/static/img/bg/hero.jpg');\n  background-size: cover;\n  background-position: center;\n  color: #fff;\n  padding: 50px;\n  text-align: center;\n  backdrop-filter: blur(10px);\n}\n.hero h2   {\n  margin-bottom: 20px;\n  text-shadow: 1px 1px 5px rgb(0 0 0); /* Text shadow for contrast */\n}\n</style>\n\n<div id=\"home\" class=\"section\">\n  <div class=\"hero\">\n    <h2>Welcome to my Page</h2>\n    <p>Discover something you don't need.</p>\n  </div>\n</div> <br>   <p  style=\"\n    text-align: center;\n\">💡 Hi I am Mrinal  web developer.. ✍️  Feel free to reach out to me for any consulting or volunteering opportunities, or simply for interesting discussions <a style=\"text-decoration: none;\" href=\"/about\">more.</a> <p>                                                                                                                                                                                                                                                                                                                                                                                                           <br>                                                                                                                               <div class=\"column-container\">\n  <div class=\"column \">\n    <a style=\"padding: 30px;\n      background-image: url(/static/img/bg/notes.jpg);\n      background-size: cover;\n      color: black;\n      font-size: 150%;\n      text-decoration: none;\n      display: block;\" href=\"/notes\">Notes</a>\n  </div>\n    <div class=\"column m-column\">\n    <a style=\"padding: 30px;\n      background-image: url(/public/images/1.jpg);\n         color: red;\n      font-size: 150%;\n      text-decoration: none;\n      display: block;\" href=\"/photos\">Photos</a>\n  </div>\n    <div class=\"column k-column\">\n    <a style=\"padding: 30px;\n      background-image: url(/static/img/bg/ringtone.jpg);\n    color: #000000;  background-size: cover;\n      background-position: center calc(50% + 50px);\n      font-size: 150%;\n      text-decoration: none;\n      display: block;\" href=\"/ringtone\">Ringtone</a>\n  </div>\n</div>\n <br>                                                                                                                                 <div class=\"card\">\n <a href=\"/snippet\">Snippet</a>\n  <a href=\"/lyrics\">Lyrics</a>\n <a href=\"/covariance-correlation-calculator\">Calculator</a>\n <a href=\"/music\">Music</a>\n    <a href=\"/mean-var-calc\">Excel</a>\n  <a href=\"/instagram\">Instagram</a>\n <a href=\"/picnic\">A day Picnic</a></div>                                                                                                                                                                                                                                                                      <br><hr>                                                                                                                                                                                                                                                                      \n    <style>\n      \n \n\nbody {\n  --space: 2rem;\n\n}\n\n.marquee {\n  --duration: 15s;\n  --gap: var(--space);\n\n  display: flex;\n  overflow: hidden;\n  user-select: none;\n  gap: 2.4rem;\n}\n\n.marquee_group {\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  justify-content: space-around;\n  gap: var(--gap);\n  min-width: 100%;\n  animation: scroll var(--duration) linear infinite;\n}\n\n\n\n@keyframes scroll {\n  0% {\n    transform: translateX(0);\n  }\n\n  100% {\n    transform: translateX(calc(-100% - var(--gap)));\n  }\n}\n    </style>\n \n\n\n <div class=\"marquee\">\n    <div class=\"marquee_group\">\n      <p>REDCASE</p>\n      <p aria-hidden=\"true\">REDCASE</p>\n      <p aria-hidden=\"true\">REDCASE</p>\n      <p aria-hidden=\"true\">REDCASE</p>\n      <p aria-hidden=\"true\">REDCASE</p>\n    </div>\n  \n    <div aria-hidden=\"true\" class=\"marquee_group\">\n      <p>REDCASE</p>\n      <p>REDCASE</p>\n      <p>REDCASE</p>\n      <p>REDCASE</p>\n      <p>REDCASE</p>\n    </div>\n  </div>\n  \n  \n\n                                                                                                                                               ",
